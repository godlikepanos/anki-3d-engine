#pragma anki technique Ssr comp
#pragma anki technique ReflectionProbeFallback comp mutators QUARTER_REZ
#pragma anki technique RtMaterialFetch rgen mutators INDIRECT_DIFFUSE_CLIPMAPS QUARTER_REZ
#pragma anki technique RtMaterialFetchInlineRt comp mutators INDIRECT_DIFFUSE_CLIPMAPS QUARTER_REZ
#pragma anki technique SpatialAccumulation comp mutators QUARTER_REZ
#pragma anki technique TemporalDenoise comp mutators QUARTER_REZ
#pragma anki technique SpatialDenoise comp mutators QUARTER_REZ
